{
  "version": 1,
  "description": "Interactive G1–G12 golden scenarios for the agent harness (LLM run is opt-in)",
  "scenarios": [
    {
      "id": "G1",
      "name": "Advisory caption flow",
      "command": "/arabic guide",
      "user_prompt": "عايز بوست لإنستجرام لكافيه في المعادي",
      "pass_signals": {
        "must_match_any": ["؟", "لهجة", "نوع", "قبل", "وضّح", "توضيح", "اسأل", "توصية"],
        "must_not_match": ["يسرنا أن نقدم", "نحن سعداء", "اكتشف كيف يمكن"],
        "min_length": 60
      }
    },
    {
      "id": "G2",
      "name": "Pro Mode ad brief",
      "command": "/arabic write meta",
      "user_prompt": "اكتب إعلان ميتا لأبليكيشن توصيل طعام في القاهرة. الجمهور: شباب 18-30. الهدف: تحميلات. اللهجة: مصري. Primary text ≤125 حرف. CTA: حمّل دلوقتي.",
      "pass_signals": {
        "must_match_any": ["مراجعة", "review", "تحميل", "حمّل", "مصر"],
        "must_not_match": [],
        "min_length": 80
      }
    },
    {
      "id": "G3",
      "name": "Prompt Coach",
      "command": "/arabic coach",
      "user_prompt": "اكتب حاجة حلوة عن المنتج بتاعنا",
      "pass_signals": {
        "must_match_any": ["ضعيف", "أقوى", "وضّح", "لهجة", "هدف", "prompt", "برومبت"],
        "must_not_match": [],
        "min_length": 100
      }
    },
    {
      "id": "G4",
      "name": "Website project",
      "command": "/arabic plan website",
      "user_prompt": "عايز أعمل موقع تسويقي لمهارة عربية — ٥ صفحات، مصري، install-first",
      "pass_signals": {
        "must_match_any": ["خطة", "plan", "sitemap", "صفحة", "مرحلة", "موافق"],
        "must_not_match": [],
        "min_length": 150
      }
    },
    {
      "id": "G5",
      "name": "Campaign bundle",
      "command": "/arabic plan campaign",
      "user_prompt": "حملة إطلاق أبليكيشن رياضة في مصر — ميتا + تيك توك + واتساب، مصري",
      "pass_signals": {
        "must_match_any": ["قناة", "ميتا", "تيك", "واتساب", "حملة", "مرحلة"],
        "must_not_match": [],
        "min_length": 150
      }
    },
    {
      "id": "G6",
      "name": "Book workflow",
      "command": "/arabic plan book",
      "user_prompt": "رواية شبابية مصري عن مطعم عائلي في الإسكندرية — ١٢ فصل",
      "pass_signals": {
        "must_match_any": ["فصل", "outline", "ملخص", "شخصيات", "خطة", "premise"],
        "must_not_match": [],
        "min_length": 150
      }
    },
    {
      "id": "G7",
      "name": "Command advisory",
      "command": "/arabic",
      "user_prompt": "محتاج مساعدة في محتوى عربي",
      "pass_signals": {
        "must_match_any": ["؟", "وضّح", "نوع", "لهجة", "قبل", "guide"],
        "must_not_match": ["يسرنا أن نقدم"],
        "min_length": 60
      }
    },
    {
      "id": "G8",
      "name": "Command write pro",
      "command": "/arabic write caption",
      "user_prompt": "كابشن إنستجرام لجيم مصري. المنتج: اشتراك شهري. اللهجة: مصري. الجمهور: شباب القاهرة. CTA: جرّب مجاناً.",
      "pass_signals": {
        "must_match_any": ["مصر", "جيم", "اشتراك", "جرّب"],
        "must_not_match": ["يسرنا أن نقدم", "اكتشف كيف يمكن"],
        "min_length": 40
      }
    },
    {
      "id": "G9",
      "name": "Command audit",
      "command": "/arabic audit",
      "input_file": "tests/golden/scenarios/fixtures/g9-audit-sample.txt",
      "user_prompt": "راجع النص المرفق",
      "pass_signals": {
        "must_match_any": ["/", "نقطة", "درجة", "score", "تدقيق", "audit", "Check"],
        "must_not_match": [],
        "min_length": 80
      }
    },
    {
      "id": "G10",
      "name": "Command plan",
      "command": "/arabic plan website",
      "user_prompt": "موقع ٣ صفحات لشركة ناشئة SaaS — هوم، تسعير، تواصل. مصري.",
      "pass_signals": {
        "must_match_any": [".arabic/projects", "خطة", "plan", "صفحة"],
        "must_not_match": [],
        "min_length": 120
      }
    },
    {
      "id": "G11",
      "name": "Command auto + project scan",
      "command": "/arabic auto explain",
      "user_prompt": "اشرح المشروع ده بعربي بسيط لصاحب مشروع مش تقني",
      "pass_signals": {
        "must_match_any": ["README", "SKILL", "arabic/", "مهارة", "مشروع"],
        "must_not_match": [".env", "API_KEY", "secret", "password"],
        "min_length": 100
      }
    },
    {
      "id": "G12",
      "name": "Dialect lock",
      "command": "/arabic write caption --dialect masri",
      "user_prompt": "كابشن لإطلاق منتج قهوة مختصة في الزمالك. مصري. CTA: جرّب النهارده.",
      "pass_signals": {
        "must_match_any": ["قهوة", "زمالك", "جرّب"],
        "must_not_match": ["يسرنا أن نقدم", "اكتشف", "نحن سعداء", "يمكنكم"],
        "min_length": 30
      }
    }
  ]
}
