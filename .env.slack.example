# Slack Bot Integration Environment Variables
# Phase 9B-1: Slack Bot
# Copy this file to .env.local and fill in the values

# === Slack App Configuration ===
# Get these from https://api.slack.com/apps

# Slack App Client ID (used for OAuth)
SLACK_CLIENT_ID=xoxb-your-client-id-here

# Slack App Client Secret (used for OAuth token exchange)
SLACK_CLIENT_SECRET=your-client-secret-here

# Slack App Signing Secret (used to verify webhook requests)
SLACK_SIGNING_SECRET=your-signing-secret-here

# Slack Bot Token (xoxb-... for bot user)
# This is auto-populated after OAuth installation, but can be set manually for testing
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# === Slack App URLs ===
# Update these to match your deployment

# OAuth callback URL (must match Slack App redirect URLs)
SLACK_OAUTH_CALLBACK_URL=https://your-domain.com/api/slack/oauth/callback

# Slack Commands endpoint
SLACK_COMMANDS_URL=https://your-domain.com/api/slack/commands

# Interactive components endpoint
SLACK_INTERACTIVE_URL=https://your-domain.com/api/slack/interactive

# Events API endpoint
SLACK_EVENTS_URL=https://your-domain.com/api/slack/events

# === Database Configuration ===
# Required for storing workspace data and quotas

# PostgreSQL connection string (used by db.query)
DATABASE_URL=postgresql://user:password@localhost:5432/arabic_skill

# === Workspace Configuration ===

# Free tier: daily request limit (default: 10)
SLACK_FREE_TIER_LIMIT=10

# Pro tier: daily request limit (default: 100)
SLACK_PRO_TIER_LIMIT=100

# Enterprise tier: unlimited (0 = no limit)
SLACK_ENTERPRISE_TIER_LIMIT=0

# === Logging & Monitoring ===

# Enable debug logging
DEBUG=slack:*

# Sentry DSN for error tracking (optional)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# === Feature Flags ===

# Enable workspace quota enforcement
ENABLE_QUOTA_ENFORCEMENT=true

# Enable workspace settings customization
ENABLE_WORKSPACE_SETTINGS=true

# Enable command logging for analytics
ENABLE_COMMAND_LOGGING=true
